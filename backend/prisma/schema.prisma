generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MENTOR
  STUDENT
}

enum SessionStatus {
  ACTIVE
  SCHEDULED
  ENDED
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  passwordHash    String
  role            UserRole      @default(STUDENT)
  avatar          String?
  bio             String?
  defaultLanguage String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  mentorSessions  Session[]     @relation("MentorSessions")
  studentSessions Session[]     @relation("StudentSessions")
  authSessions    AuthSession[]
  messages        Message[]
}

model AuthSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id         String        @id @default(cuid())
  title      String
  status     SessionStatus @default(ACTIVE)
  mentorId   String
  studentId  String?
  inviteCode String        @unique
  code       String?
  language   String?       @default("javascript")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  endedAt    DateTime?
  mentor     User          @relation("MentorSessions", fields: [mentorId], references: [id], onDelete: Cascade)
  student    User?         @relation("StudentSessions", fields: [studentId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([mentorId])
  @@index([studentId])
  @@index([status])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId])
}
