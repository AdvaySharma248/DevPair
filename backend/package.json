{
  "name": "devpair-backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --experimental-strip-types scripts/dev.ts",
    "dev:server": "node --env-file=.env --experimental-strip-types src/server.ts",
    "start": "node --env-file=.env --experimental-strip-types src/server.ts",
    "dev:runner": "node --watch --experimental-strip-types services/code-execution/index.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "seed:users": "node --env-file=.env --experimental-strip-types scripts/seed-users.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "prisma": "^6.11.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "typescript": "^5"
  }
}
